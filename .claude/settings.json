{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(python3 -m json.tool)",
      "Bash(curl -s http://localhost:8005/status)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:5173/)",
      "Bash(curl -s http://localhost:5173/api/status)",
      "Bash(pkill -f \"vite --port 5173\")",
      "Bash(curl -s -X POST http://localhost:8005/auth/login -H 'Content-Type: application/x-www-form-urlencoded' -d 'username=admin&password=changeme')"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Regex",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/vexp-guard.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
