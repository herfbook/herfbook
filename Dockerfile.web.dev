# Dev image for herfbook-web.
# Pairs with docker-compose.dev.yml, which mounts frontend/dist at
# /usr/share/nginx/html as a read-only volume.
#
# This image intentionally does NOT bake in the frontend build. The
# host runs `npm run build` (or `npm run dev` separately on :5174)
# and the result reflects in Nginx without an image rebuild.

FROM nginx:alpine

COPY nginx/default.conf /etc/nginx/conf.d/default.conf

# Ensure the html directory exists so Nginx doesn't error when the
# mount is briefly missing.
RUN mkdir -p /usr/share/nginx/html

EXPOSE 80
