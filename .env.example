# ──────────────────────────────────────────────
# HerfBook environment configuration
# Copy this file to .env and edit before running.
# ──────────────────────────────────────────────

# Database
POSTGRES_USER=herfbook
POSTGRES_PASSWORD=changeme
POSTGRES_DB=herfbook

# MinIO object storage
MINIO_ROOT_USER=herfbook
MINIO_ROOT_PASSWORD=changeme

# Auth — replace with a long random string in production
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme-replace-with-a-long-random-string

# Community data sync
COMMUNITY_SYNC_ON_STARTUP=true
GITHUB_COMMUNITY_REPO=herfbook/herfbook

# Optional: path to a YAML config file.
# When set and the file exists, values from the file are loaded
# before env vars, so env vars always take precedence.
# HERFBOOK_CONFIG_FILE=config.yml
